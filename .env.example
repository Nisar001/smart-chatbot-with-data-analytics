APP_NAME=Smart Multi-User Chatbot with Data Analytics
APP_VERSION=1.0.0
ENVIRONMENT=development
API_PREFIX=/api/v1
DEBUG=false
CORS_ORIGINS_RAW=http://localhost:3000,http://localhost:5173

DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/smart_chatbot
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

JWT_SECRET_KEY=replace-with-secure-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

GOOGLE_API_KEY=your_google_api_key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_CHAT_FALLBACK_MODELS_RAW=gemini-2.0-flash-lite,gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_FALLBACK_MODELS_RAW=models/text-embedding-004,models/embedding-001
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=1024
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=3

FAISS_INDEX_DIR=storage/faiss
UPLOAD_DIR=storage/uploads
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=4
BATCH_EMBEDDING_SIZE=32

SOCKET_CORS_ORIGINS_RAW=*
REDIS_URL=redis://redis:6379/0
ENABLE_CACHE=true
CACHE_TTL_SECONDS=300
DEFAULT_LATENCY_THRESHOLD_MS=2000
